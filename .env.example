# --- Telegram ---
BOT_TOKEN=123456:CHANGE_ME

# --- Database ---
DATABASE_URL=postgresql+asyncpg://inci:inci@postgres:5432/inci
ALEMBIC_DATABASE_URL=postgresql+psycopg2://inci:inci@postgres:5432/inci

# --- Redis (used for rate limiting + CosIng/PubChem cache) ---
REDIS_URL=redis://redis:6379/0

# --- Tesseract OCR ---
TESSERACT_CMD=
TESSERACT_LANGS=eng+rus

# --- skinsignal.ru enrichment (russian translation, comedogenicity, traits) ---
# Set to false to disable scraping skinsignal.ru entirely.
SKINSIGNAL_ENABLED=true
SKINSIGNAL_MAX_LOOKUPS=6

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO
SUPPORT_USERNAME=your_support
